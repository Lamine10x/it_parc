<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_affectation_list" model="ir.ui.view">
        <field name="name">it.affectation.list</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <list>
                <field name="equipment_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="motif"/>
            </list>
        </field>
    </record>

    <record id="view_it_affectation_form" model="ir.ui.view">
        <field name="name">it.affectation.form</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="equipment_id"/>
                        <field name="employee_id"/>
                        <field name="department_id"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                    </group>
                    <field name="motif" placeholder="Motif de l'affectation ou mutation"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_it_affectation" model="ir.actions.act_window">
        <field name="name">Historique affectations</field>
        <field name="res_model">it.affectation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
