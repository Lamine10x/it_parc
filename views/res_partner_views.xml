<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_it_parc" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.it.parc</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_it_contrats" type="object"
                        class="oe_stat_button" icon="fa-file-text-o"
                        groups="it_parc.group_it_manager">
                    <field name="contrat_count" widget="statinfo"
                           string="Contrats IT"/>
                </button>
            </div>
        </field>
    </record>
</odoo>
