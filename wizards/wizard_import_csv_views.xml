<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_import_csv_form" model="ir.ui.view">
        <field name="name">wizard.import.csv.form</field>
        <field name="model">wizard.import.csv</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Fichier à importer" invisible="state == 'done'">
                        <field name="csv_file" widget="binary" filename="csv_filename"/>
                        <field name="csv_filename" invisible="1"/>
                        <field name="delimiter"/>
                        <field name="encoding"/>
                    </group>
                    <group string="Résumé de l'import" invisible="state == 'draft'">
                        <field name="count_created" readonly="1"/>
                        <field name="count_ignored" readonly="1"/>
                        <field name="count_error" readonly="1"/>
                    </group>
                    <group string="Détail ligne par ligne" invisible="state == 'draft'">
                        <field name="result_line_ids" nolabel="1">
                            <list decoration-success="status == 'created'"
                                  decoration-warning="status == 'ignored'"
                                  decoration-danger="status == 'error'">
                                <field name="row_number"/>
                                <field name="name"/>
                                <field name="serial_number"/>
                                <field name="status" widget="badge"
                                       decoration-success="status == 'created'"
                                       decoration-warning="status == 'ignored'"
                                       decoration-danger="status == 'error'"/>
                                <field name="message"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import" string="Lancer l'import"
                            type="object" class="btn-primary"
                            invisible="state == 'done'"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_import_csv" model="ir.actions.act_window">
        <field name="name">Import CSV équipements</field>
        <field name="res_model">wizard.import.csv</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
